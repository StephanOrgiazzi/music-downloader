{
  "name": "music-downloader-runtime",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "Genius to MP3 downloader runtime",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "use": "npm install && npm run doctor",
    "cli": "tsx src/cli.ts",
    "doctor": "tsx src/cli.ts doctor",
    "preview": "tsx src/cli.ts preview",
    "download": "tsx src/cli.ts download",
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "execa": "^9.6.0",
    "ffmpeg-static": "^5.2.0",
    "yargs": "^18.0.0",
    "yt-dlp-wrap": "^2.3.12",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/yargs": "^17.0.33",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
